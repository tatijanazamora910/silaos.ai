# ============================================================================
# ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file and rename to .env, then fill in with actual values.
# NEVER commit .env to version control - it contains secrets!
# See .gitignore and SETUP_GUIDE.md for security details.

# ============================================================================
# REQUIRED: Operating Mode
# ============================================================================
# Set to 'demo' for development/testing with mock data
# Set to 'live' to connect to real studio management systems
MODE=demo
OPERATING_MODE=demo

# ============================================================================
# REQUIRED (LIVE mode only): Studio Platform Selection
# ============================================================================
# Choose one: mindbody, arketa, wellnessliving, momence
STUDIO_PLATFORM=mindbody

# ============================================================================
# Platform Credentials
# ============================================================================
# Add ONLY the credentials for your chosen platform
# Delete or leave blank the credentials you don't need

# Mindbody (https://developer.mindbodyonline.com)
MINDBODY_API_KEY=

# Arketa (https://arketa.com)
ARKETA_API_KEY=

# WellnessLiving / Zen Planner (contact support)
WL_USERNAME=
WL_PASSWORD=

# Momence (https://www.momence.com)
MOMENCE_API_KEY=
MOMENCE_BUSINESS_ID=

# ============================================================================
# Optional: Integration Services
# ============================================================================
# ManyChat configuration
MANYCHAT_API_KEY=
MANYCHAT_WEBHOOK_SECRET=

# SchedulingKit configuration
SCHEDULINGKIT_API_KEY=
SCHEDULINGKIT_BUSINESS_ID=

# ============================================================================
# Optional: Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================================
# Optional: Database (for future use)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=pilates_studio

# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# ⚠️  NEVER hardcode credentials in source files
# ⚠️  NEVER commit this file with credentials to version control
# ⚠️  NEVER share .env files via email or unencrypted channels
# ⚠️  NEVER log credentials or API keys in any output
# ⚠️  Rotate credentials regularly (see SETUP_GUIDE.md)
#
# For production deployment:
# - Use environment variables from your hosting platform
# - Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# - Never store .env files on production servers
# - Use separate credentials per environment (dev/staging/production)
