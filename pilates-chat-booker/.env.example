################################################################################
# PILATES CHAT BOOKER - ENVIRONMENT CONFIGURATION
#
# Copy this file to .env and fill in the values for your studio.
# NEVER commit the .env file to version control - it contains secrets!
#
# For security: Use a .env file locally and environment variables in production
################################################################################

# ============================================================================
# OPERATING MODE (Required for startup)
# ============================================================================
# Options: "demo" (mock data, no credentials needed) | "live" (real integrations)
# Use "demo" during development and testing
# Switch to "live" when ready to connect to real studio management system
NODE_ENV=development
OPERATING_MODE=demo

# ============================================================================
# STUDIO PLATFORM SELECTION (Required when OPERATING_MODE=live)
# ============================================================================
# Options: "mindbody", "arketa", "wellnessliving", "momence"
# Select the platform your studio uses for class management
STUDIO_PLATFORM=mindbody

# ============================================================================
# PORT & SERVER CONFIGURATION
# ============================================================================
PORT=3000
LOG_LEVEL=info

# ============================================================================
# MINDBODY CONFIGURATION
# ============================================================================
# Mindbody (by Zenoti) - REST API with public sandbox support
# Get credentials: https://developer.mindbodyonline.com
#
# MINDBODY_API_KEY:
#   - Description: API key for Mindbody authentication
#   - Where to find: Mindbody Developer Portal → API Credentials → Authentication Keys
#   - Format: Bearer token or API key string
#   - Required for: STUDIO_PLATFORM=mindbody
#
# Testing: Uses SiteID -99 (Mindbody public sandbox)
MINDBODY_API_KEY=your_mindbody_api_key_here

# ============================================================================
# ARKETA CONFIGURATION
# ============================================================================
# Arketa - Event-driven scheduling platform with webhook support
# Get credentials: https://arketa.com or contact Arketa support
#
# ARKETA_API_KEY:
#   - Description: API key for Arketa authentication
#   - Where to find: Arketa Admin Portal → Integrations → API Keys
#   - Format: Bearer token or API key string
#   - Required for: STUDIO_PLATFORM=arketa
#   - Note: Arketa also requires webhook endpoint configuration in their dashboard
#
# Webhook endpoint: https://your-domain/api/arketa/webhook
ARKETA_API_KEY=your_arketa_api_key_here

# ============================================================================
# WELLNESSLIVING CONFIGURATION
# ============================================================================
# WellnessLiving (Zen Planner) - Session-based authentication
# Get credentials: Contact your WellnessLiving/Zen Planner account manager
#
# WL_USERNAME:
#   - Description: WellnessLiving admin account username/email
#   - Where to find: Your WellnessLiving login email
#   - Format: Email address or username
#   - Required for: STUDIO_PLATFORM=wellnessliving
#   - Security: Use a dedicated service account if possible
#
# WL_PASSWORD:
#   - Description: WellnessLiving admin account password
#   - Where to find: Your WellnessLiving account password
#   - Format: Plain text (stored securely in .env)
#   - Required for: STUDIO_PLATFORM=wellnessliving
#   - Security: Use a strong, unique password
#   - Session duration: 30 minutes (auto-refresh handled automatically)
#
WL_USERNAME=your_wellnessliving_username_here
WL_PASSWORD=your_wellnessliving_password_here

# ============================================================================
# MOMENCE CONFIGURATION
# ============================================================================
# Momence - Modern REST API with multi-tenant support
# Get credentials: https://www.momence.com or contact Momence support
#
# MOMENCE_API_KEY:
#   - Description: API key for Momence authentication
#   - Where to find: Momence Dashboard → Settings → API Keys
#   - Format: Bearer token
#   - Required for: STUDIO_PLATFORM=momence
#
# MOMENCE_BUSINESS_ID:
#   - Description: Unique identifier for your studio business in Momence
#   - Where to find: Momence Dashboard → Settings → Business ID or API Documentation
#   - Format: Alphanumeric string or UUID
#   - Required for: STUDIO_PLATFORM=momence
#   - Note: Used for multi-tenant routing in HTTP headers (X-Business-ID)
#
MOMENCE_API_KEY=your_momence_api_key_here
MOMENCE_BUSINESS_ID=your_momence_business_id_here

# ============================================================================
# CHATBOT INTEGRATIONS (Optional)
# ============================================================================
# These are used for sending booking confirmations and chat messages

# ManyChat API Configuration
# Get credentials: https://manychat.com → Integrations → API
# Used for sending messages via ManyChat chatbot
MANYCHAT_API_KEY=your_manychat_api_key_here
MANYCHAT_WEBHOOK_SECRET=your_webhook_secret_here

# SchedulingKit Configuration
# Get credentials: https://schedulingkit.io or internal service
# Alternative booking/scheduling integration
SCHEDULINGKIT_API_KEY=your_schedulingkit_api_key_here
SCHEDULINGKIT_BUSINESS_ID=your_business_id_here

# ============================================================================
# DATABASE CONFIGURATION (Optional - for future use)
# ============================================================================
# PostgreSQL database for storing bookings, client info, analytics
# Leave blank if using in-memory/mock data only
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=pilates_studio

# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================
#
# 1. NEVER commit .env to version control - add to .gitignore
#    echo ".env" >> .gitignore
#
# 2. Use environment variables in production, not .env files
#    Deploy secrets via Docker secrets, AWS Secrets Manager, HashiCorp Vault, etc.
#
# 3. Rotate credentials regularly:
#    - API keys: At least annually or when staff changes
#    - Passwords: Follow your studio's security policy
#    - Webhook secrets: Rotate after suspected compromise
#
# 4. Use dedicated service accounts:
#    - Create a separate user in your studio management system
#    - Grant minimal necessary permissions (read bookings, create bookings)
#    - Avoid using personal admin credentials
#
# 5. Monitor API usage:
#    - Check logs for failed authentication attempts
#    - Review API activity logs in your studio management system
#    - Set up alerts for unusual patterns
#
# 6. Secure the .env file:
#    - Restrict file permissions: chmod 600 .env
#    - Store in secure location with limited access
#    - Back up securely if needed
#
# ============================================================================
# CONFIGURATION CHECKLIST FOR STUDIO SETUP
# ============================================================================
#
# When onboarding a new studio:
#
# [ ] Step 1: Identify their studio management platform
#     - Have them run: "Which platform does your studio use?"
#     - Verify: Mindbody | Arketa | WellnessLiving | Momence
#
# [ ] Step 2: Collect platform credentials
#     - Mindbody: Ask for API Key
#     - Arketa: Ask for API Key + webhook URL requirements
#     - WellnessLiving: Ask for admin username and password
#     - Momence: Ask for API Key + Business ID
#
# [ ] Step 3: Create service account (if possible)
#     - Request dedicated user account in their system
#     - Minimize permissions (read + create bookings only)
#     - Document the temporary password setup
#
# [ ] Step 4: Configure environment
#     - Set OPERATING_MODE=live
#     - Set STUDIO_PLATFORM=[their platform]
#     - Fill in platform-specific credentials
#     - Test connectivity before going live
#
# [ ] Step 5: Test connectivity
#     - Call: POST /api/adapters/check-availability
#     - Verify: Adapter can fetch real class data
#     - Confirm: Booking flow works end-to-end
#
# [ ] Step 6: Monitor and support
#     - Set LOG_LEVEL=info or debug initially
#     - Review logs for any authentication errors
#     - Create support channel for credential rotation
#
# ============================================================================
